# Stage 1: build
FROM eclipse-temurin:21-jdk AS builder
WORKDIR /app
COPY . .
RUN ./mvnw package -pl ecommerce-hub-api -am -DskipTests

# Stage 2: runtime
FROM eclipse-temurin:21-jre
WORKDIR /app
COPY --from=builder /app/ecommerce-hub-api/target/ecommerce-hub-api.jar app.jar
ENTRYPOINT ["java", "-jar", "app.jar"]